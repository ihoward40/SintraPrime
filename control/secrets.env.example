# DO NOT COMMIT REAL TOKENS.
# Copy to control/secrets.env and fill values.

# Notion
NOTION_TOKEN=
NOTION_API_VERSION=2022-06-28
NOTION_API_BASE=https://api.notion.com

# Notion (Slack case ingestion)
NOTION_CASES_DB=
# Optional: property names in your Notion cases DB
NOTION_CASE_TITLE_PROP=Name
NOTION_CASE_PROP_CREDITOR=Creditor
NOTION_CASE_PROP_CASEID=Case Id
NOTION_CASE_PROP_REQUESTED_BY=Requested By
NOTION_CASE_PROP_SOURCE=Source
NOTION_CASE_PROP_SLACK_CHANNEL=Slack Channel
NOTION_CASE_PROP_SLACK_USER=Slack User

# Notion (Autonomous Paralegal Queue)
NOTION_PARALEGAL_DB=

# Notion (Level 2 Paralegal OS mirroring)
# Used by ui/integrations/notionParalegalSync.js to mirror cases/tasks into Notion databases.
PARALEGAL_CASE_DB=
PARALEGAL_TASK_DB=

# Make.com
MAKE_TOKEN=
MAKE_API_BASE=https://api.make.com
MAKE_ORG_ID=

# Make.com (webhook trigger dispatch from UI)
MAKE_WEBHOOK_URL=
MAKE_WEBHOOK_SECRET=

# Inbound unified webhooks (recommended: keep these SIGNED + limited)
# Signature headers expected:
# - X-Sintra-Timestamp: unix seconds
# - X-Sintra-Signature: sha256=<hex> (HMAC over "{ts}.{rawBody}")
# - X-Sintra-Nonce: optional nonce for replay protection
SINTRA_GATEWAY_SECRET=
SINTRA_LOG_SECRET=
TIKTOK_BRIDGE_SECRET=

# Local-only: bypass signature checks (NOT for production)
SINTRA_WEBHOOK_ALLOW_UNVERIFIED=0

# Security tuning
SINTRA_WEBHOOK_MAX_SKEW_S=300
SINTRA_WEBHOOK_NONCE_TTL_S=600

# Rate limits (per-IP per-minute)
SINTRA_GATEWAY_RATELIMIT=120
SINTRA_LOG_RATELIMIT=240
SINTRA_TIKTOK_RATELIMIT=120

# Fanout: also emit body.type as an eventBus event name
SINTRA_GATEWAY_EMIT_TYPED_EVENTS=1

# Calendar (webhook adapter; can point to a Make scenario that writes to Google Calendar)
GOOGLE_CALENDAR_WEBHOOK_URL=

# Slack
SLACK_BOT_TOKEN=
# Optional alias (supported by the UI Slack routes)
SLACK_TOKEN=
# Optional: Incoming Webhook URL for emergency-only alerts (one-way)
# Recommended use: crash logs, boot diagnostics, critical notifications.
SLACK_ALERT_WEBHOOK=
# Offline mode: disables outbound Slack calls (lets UI boot even if token is expired)
SLACK_OFFLINE=0
# Required for verifying Slack slash commands in production
SLACK_SIGNING_SECRET=
# Local-only override to allow slash command testing without signature verification
SLACK_ALLOW_UNVERIFIED=0
# Optional: Slack app token for Socket Mode (not used by this sweep MVP)
SLACK_APP_TOKEN=

# Optional: default channel (prefer a channel ID like C0A2B0WASBH)
# If you do use a name, DO NOT include '#'.
# You can resolve a channel name to an ID locally via:
#   node scripts/resolve-slack-channel-id.mjs #all-ikesolutions
SLACK_DEFAULT_CHANNEL=

# Autonomous Paralegal (prefer channel ID; if using a name, omit '#')
SLACK_PARALEGAL_CHANNEL=

# Slack creditor mentions → auto enforcement (OFF by default)
SLACK_AUTO_ENFORCE_ON_CREDITOR=0

# Autonomous paralegal task/case engine (OFF by default)
PARALEGAL_AUTONOMOUS=0

# If enabled, require CLUSTER_ADMIN_SECRET header for /api/paralegal/state
PARALEGAL_STATE_REQUIRE_ADMIN=0

# Debug event injection (OFF by default)
# Enables: POST /api/debug/events/emit
DEBUG_EVENTS_ENABLE=0
# If enabled, requires X-Sintra-Admin / CLUSTER_ADMIN_SECRET for debug emit
DEBUG_EVENTS_REQUIRE_ADMIN=1

# Optional: Slack OAuth token rotation support (OFF by default)
# NOTE: Many Slack bot tokens are not refreshable; in that case you must "Reinstall to Workspace".
SLACK_ENABLE_OAUTH_REFRESH=0
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REFRESH_TOKEN=

# Slack Token Watchtower (recommended)
# If unset, auto-enables when SLACK_BOT_TOKEN is present.
SLACK_WATCHTOWER=1
# Token cache used by src/watchers/slackTokenWatchdog.js (writes secrets to disk!)
# Default path used by the watchtower is: data/slack_token.json

# IMPORTANT: To avoid getting stuck on an old cached xoxb token, the Watchtower will NOT
# override SLACK_BOT_TOKEN when it is present.
# If you want to prefer the cache anyway (NOT recommended), set:
# SLACK_WATCHTOWER_PREFER_CACHE=1
# To allow Watchtower to write refreshed tokens back to disk (writes secrets!), set:
# SLACK_WATCHTOWER_WRITE_CACHE=1

# Slack test suite routes (recommended to keep admin-gated)
SLACK_TEST_REQUIRE_ADMIN=1

# Slack Watchdog (proactive auth.test + optional OAuth refresh)
# If SLACK_WATCHDOG=1, the UI periodically checks Slack auth and attempts refresh when token expires.
# If SLACK_WATCHDOG is unset, it auto-enables when a Slack token is present.
SLACK_WATCHDOG=1
# Default is 12 minutes.
SLACK_WATCHDOG_INTERVAL_MS=720000
# Optional: persist refreshed token to disk so it can survive reboots.
# WARNING: this writes secrets to disk; use only on trusted hosts.
SLACK_TOKEN_CACHE_PATH=

# OpenAI (for /sintra explain)
OPENAI_API_KEY=
OPENAI_MODEL=

# Creditor Behavior AI Prediction Engine (CBAPE)
BEHAVIOR_PREDICTION_ENABLED=0
BEHAVIOR_PREDICTION_MODEL=gpt-4.1-mini
BEHAVIOR_PREDICTION_CHANNEL=#all-ikesolutions
BEHAVIOR_HISTORY_PATH=output/data/behaviorHistory.json

# Adaptive Enforcement AI
ADAPTIVE_ENFORCEMENT_ENABLED=0
ADAPTIVE_ENFORCEMENT_VOICE=1

# Discovery Engine (auto-case creation)
DISCOVERY_ENGINE_ENABLED=0
# Dedupe window for repeated observations (ms)
DISCOVERY_DEDUPE_WINDOW_MS=600000

# Enforcement global mode (applies as default for new case states)
ENFORCEMENT_SYSTEM_MODE=standard

# Optional: protect dashboard APIs with X-API-Key
DASHBOARD_API_KEY=

# Autonomous Mode
AUTONOMOUS_ENABLED=0
AUTONOMOUS_INTERVAL_MS=300000
AUTONOMOUS_CHANNEL=#all-ikesolutions
AUTONOMOUS_BRIEFING_HOUR=9
AUTONOMOUS_BRIEFING_MINUTE=0

# Autonomous Enforcement Chain
AUTONOMOUS_ENFORCEMENT_STAGE_DAYS=30

# Playbook Pack channel routing (prefer channel ID; if using a name, omit '#')
PLAYBOOK_CHANNEL_VERIZON=
PLAYBOOK_CHANNEL_JUNK_DEBT=
PLAYBOOK_CHANNEL_CHASE_EWS=
PLAYBOOK_CHANNEL_DAKOTA=

# ElevenLabs (Mythic Speech Engine)
# Emergency switch: disable all TTS synthesis + uploads (recommended until voice IDs are real)
DISABLE_TTS=0
# Local-only: mock TTS (generates silent WAV buffers; bypasses ElevenLabs API calls)
TTS_MOCK=0
ELEVENLABS_API_KEY=
# Optional alias (supported by the UI voice routes)
ELEVEN_API_KEY=
# Optional: model override (defaults to eleven_multilingual_v2)
ELEVEN_MODEL_ID=
# Optional override (defaults to https://api.elevenlabs.io)
ELEVENLABS_BASE_URL=

# Voice routing config for UI server routes
# Default: config/voices.json
ELEVEN_VOICES_PATH=config/voices.json

# Optional per-persona voice overrides (lets you hotfix voice IDs via env)
# Examples:
# ELEVEN_ORACLE=<real_elevenlabs_voice_id>
# ELEVEN_DRAGON=<real_elevenlabs_voice_id>
# ELEVEN_JUDGE=<real_elevenlabs_voice_id>
# Also supported: ELEVEN_VOICE_<PERSONA>, ELEVEN_<PERSONA>_VOICE_ID, ELEVEN_VOICE_ID_FOR_<PERSONA>
# You can verify a voice_id locally (no secrets printed) via:
#   node scripts/elevenlabs-voice-lookup.mjs --id <voice_id>
# Also supported (ops playbook naming):
# ELEVEN_VOICE_ID_FOR_BRICK_CITY_ORACLE=<real_elevenlabs_voice_id>
# ELEVEN_VOICE_ID_FOR_DRAGON_DUE_PROCESS=<real_elevenlabs_voice_id>
# ELEVEN_VOICE_ID_FOR_JUDGE_INVISIBLE=<real_elevenlabs_voice_id>
# ELEVEN_VOICE_ID_FOR_SUPREME_COURT_MODE=<real_elevenlabs_voice_id>
# ELEVEN_VOICE_ID_FOR_SHADOW_TRUSTEE=<real_elevenlabs_voice_id>
# Also supported (V2 naming):
# ELEVEN_BRICK_CITY_ORACLE_V2=<real_elevenlabs_voice_id>
# ELEVEN_DRAGON_DUE_PROCESS_V2=<real_elevenlabs_voice_id>
# ELEVEN_JUDGE_INVISIBLE_V2=<real_elevenlabs_voice_id>
# ELEVEN_SUPREME_COURT_MODE_V2=<real_elevenlabs_voice_id>
# ELEVEN_SHADOW_TRUSTEE_HYBRID_ELITE=<real_elevenlabs_voice_id>
#+#+#+#+# Compatibility naming (as used in ops playbooks)
ELEVEN_ORACLE_VOICE_ID=
ELEVEN_DUE_PROCESS_VOICE_ID=
ELEVEN_JUDGE_INVISIBLE_VOICE_ID=
ELEVEN_ISIAH=
ELEVEN_ORACLE=
ELEVEN_GUARDIAN=
ELEVEN_SCRIBE=
ELEVEN_SCHOLAR=
ELEVEN_JUDGE=
ELEVEN_TRICKSTER=
ELEVEN_DRAGON=
ELEVEN_ANGEL=
# Where generated audio is written (ignored by git)
# Default: artifacts/voice/router
ELEVEN_OUTPUT_DIR=artifacts/voice/router

# Slack flood protection (recommended)
# Global postMessage pacing to avoid rate-limit storms across multiple subsystems.
SLACK_MIN_POST_INTERVAL_MS=1500
# Optional jitter to de-synchronize bursts
SLACK_POST_JITTER_MS=50

# Voice webhook server (optional)

# Voice autopilot (optional)
# When enabled, key pipeline events will emit voice briefings automatically (best-effort + deduped).
SLACK_VOICE_AUTOPILOT=0
VOICE_WEBHOOK_PORT=8789

# Watch Mode (UI proof)
WATCH_MODE=0
PLAYWRIGHT_HEADLESS=1
PLAYWRIGHT_SLOW_MO=0

# UI server port binding
# UI_PORT=3001
# UI_HOST=127.0.0.1
# If UI_PORT is busy, try UI_PORT+1 ... UI_PORT+UI_PORT_FALLBACK_RANGE
UI_PORT_FALLBACK_RANGE=20

# Allow local dev UIs (e.g. Next.js console on :3000) to call the router APIs.
# Comma-separated origins, or "*" (not recommended).
UI_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Admin control plane token for /api/admin/* (required to enable admin endpoints)
CLUSTER_ADMIN_SECRET=

# Optional: cluster identity (single-node defaults are fine)
# NODE_ID=
# NODE_ROLE=primary
# NODE_CAPABILITIES=router,dashboard,enforcement

# Optional: force browser engine (chromium|firefox|webkit)
PLAYWRIGHT_BROWSER=chromium

# Optional: base URLs to tour/record (requires existing login)
WATCH_NOTION_URL=
WATCH_MAKE_URL=
WATCH_SLACK_URL=

# Optional: which systems to tour (comma-separated)
WATCH_SYSTEMS=notion,make,slack

# Optional: choose when tours run (comma-separated). If unset, defaults remain:
# - approval (awaiting approval)
# - postapply (after apply)
WATCH_PHASES=approval,apply,postapply

# Optional: take per-step screenshots during apply (still requires WATCH_MODE=1)
WATCH_STEP_SCREENSHOTS=0

# Optional: append-only hash chaining across run artifacts (tamper-evident; non-governing)
RUN_HASH_CHAIN=0

# Drive tooling (recommended)
SINTRAPRIME_DRIVES_CONFIG=config/drives.json
SINTRAPRIME_DRIVE_RECEIPTS_DIR=runs/drive/receipts
LOG_LEVEL=info

# Drive tooling (OAuth)
GDRIVE_OAUTH_CLIENT_ID=
GDRIVE_OAUTH_CLIENT_SECRET=
GDRIVE_OAUTH_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob
# Per-account refresh token key is deliberate and maps to the drives.json account.
GDRIVE_OAUTH_REFRESH_TOKEN__HOWARDISIAH_GMAIL_COM=

# Drive tooling (Service Account)
# Store the entire JSON key in this env var.
GSA_TRUST_VAULT_JSON=

# Drive tooling (Make proxy fallback)
MAKE_DRIVE_ENSUREPATH_URL=
