# Airtable CRM Configuration
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control

# Airtable API key (from https://airtable.com/account/api)
# Generate a token with data.records:read and data.records:write scopes
# Format: pat_[alphanumeric characters]
AIRTABLE_API_KEY=your_api_key_here

# Airtable Base ID (from your base URL: airtable.com/app[base_id])
# Format: app[alphanumeric characters]
AIRTABLE_BASE_ID=your_base_id_here

# Optional: Stripe API key for payment sync
# Format: sk_live_[alphanumeric] or sk_test_[alphanumeric]
STRIPE_API_KEY=your_stripe_key_here

# Optional: Stripe Webhook secret for event handling
# Format: whsec_[alphanumeric]
STRIPE_WEBHOOK_SECRET=your_webhook_secret_here

# Optional: Slack webhook for notifications
# Format: https://hooks.slack.com/services/[path]
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Optional: Environment (development, staging, production)
ENVIRONMENT=production

# Optional: Enable debug logging
DEBUG=false
