    "requireRootAllowlist": true
  },
  "targets": [
    {
      "alias": "my_drive_ops",
      "auth": {
        "type": "oauth",
        "account": "howardisiah@gmail.com",
        "clientIdSecretRef": "GDRIVE_OAUTH_CLIENT_ID",
        "clientSecretSecretRef": "GDRIVE_OAUTH_CLIENT_SECRET",
        "refreshTokenSecretRef": "GDRIVE_OAUTH_REFRESH_TOKEN__HOWARDISIAH_GMAIL_COM"
      },
      "driveType": "folder",
      "approvedRoots": ["REPLACE_WITH_APPROVED_ROOT_FOLDER_ID"],
      "defaultRoot": "REPLACE_WITH_APPROVED_ROOT_FOLDER_ID"
    },
    {
      "alias": "shared_drive_marketing",
      "auth": {
        "type": "oauth",
        "account": "howardisiah@gmail.com",
        "clientIdSecretRef": "GDRIVE_OAUTH_CLIENT_ID",
        "clientSecretSecretRef": "GDRIVE_OAUTH_CLIENT_SECRET",
        "refreshTokenSecretRef": "GDRIVE_OAUTH_REFRESH_TOKEN__HOWARDISIAH_GMAIL_COM"
      },
      "driveType": "folder",
      "approvedRoots": ["REPLACE_WITH_APPROVED_ROOT_FOLDER_ID"],
