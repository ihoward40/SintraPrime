# ElevenLabs
ELEVEN_API_KEY=REPLACE_WITH_YOUR_ELEVENLABS_API_KEY

# Slack (optional)
SLACK_BOT_TOKEN=REPLACE_WITH_YOUR_SLACK_BOT_TOKEN
# Prefer channel ID (C0123456789). Channel names work for some setups but are less reliable.
SLACK_DEFAULT_CHANNEL=#your-channel-name

# Webhook server
WEBHOOK_PORT=5005
