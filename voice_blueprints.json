      "routing": {
        "event_types": ["litigation.*", "doc.generated", "filing.*"],
        "fallback_priority": 3
      },
      "env_aliases": [
        "ELEVEN_JUDGE_INVISIBLE_V2",
        "ELEVEN_VOICE_JUDGE",
        "ELEVEN_VOICE_ID_FOR_JUDGE_INVISIBLE"
      ]
    },
    {
      "persona": "supreme",
      "display_name": "SUPREME_COURT_MODE_V2",
      "intent": "Cinematic resonance + slowed cadence for highest-tier filings",
      "routing": {
        "event_types": ["supreme.*", "ai.argument.ready"],
        "fallback_priority": 99
      },
      "env_aliases": [
        "ELEVEN_SUPREME_COURT_MODE_V2",
        "ELEVEN_VOICE_SUPREME",
        "ELEVEN_VOICE_ID_FOR_SUPREME_COURT_MODE"
      ]
