{
  "$id": "https://schemas.sintraprime.io/socialos/api/schedule_on_best_time_request.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["actor", "content_id", "platform"],
  "properties": {
    "actor": { "type": "string", "minLength": 1 },
    "content_id": { "type": "string", "format": "uuid" },
    "platform": { "type": "string", "minLength": 1 },
    "min_confidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.4 },
    "horizon_days": { "type": "integer", "minimum": 1, "maximum": 30, "default": 7 }
  }
}
